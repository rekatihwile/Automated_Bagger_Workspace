__pycache__/
**/__pycache__/
*.pyc
*.pyo

# CAD and archives
*.stl
*.step
*.STL
*.SLDPRT
*.SLDASM
*.zip
*.tar
*.gz
*.7z

# Photos 
*.jpg
*.jpeg
